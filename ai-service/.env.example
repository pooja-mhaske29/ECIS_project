# ECIS geospatial intelligence service configuration

HOST=127.0.0.1
PORT=8000
DEBUG=false

# Public OpenStreetMap services used for live geospatial evidence.
# Keep a clear User-Agent to comply with public service usage policies.
ECIS_USER_AGENT=ECIS-App/2.1 contact=your-email@example.com
NOMINATIM_API_URL=https://nominatim.openstreetmap.org/reverse
OVERPASS_API_URL=https://overpass-api.de/api/interpreter

# Radius used by Overpass to collect nearby environmental features.
ECIS_SIGNAL_RADIUS_M=3000
